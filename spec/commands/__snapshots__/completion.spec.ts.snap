`;

exports[`completion > shell generators > zsh output matches snapshot 1`] = `
"#compdef ggt

_ggt_dynamic() {
  local -a results
  results=(\${(f)"$(ggt --__complete "\${_ggt_words[@]:1}" 2>/dev/null)"})
  compadd -a results
}

_ggt_var() {
  local -a subcommands
  local state

  _arguments -C \\
    '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
    '--version[Print the ggt version]' \\
    '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
    '--telemetry[Enable telemetry]' \\
    '--json[Output as JSON where supported]' \\
    '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
    '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
    '1:subcommand:->subcommand' \\
    '*::arg:->args'

  case $state in
    subcommand)
      subcommands=(
        'list:List all environment variable keys'
        'get:Print the value of an environment variable'
        'set:Set one or more environment variables'
        'delete:Delete one or more environment variables'
        'import:Import variables from another environment or file'
      )
      _describe -t subcommands 'var subcommand' subcommands
      ;;
    args)
      case $words[1] in
        list)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic'
          ;;
        get)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic'
          ;;
        set)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '(--secret -s)''--secret[Mark the variable as secret (write-only)]' \\
            '(--secret -s)''-s[Mark the variable as secret (write-only)]'
          ;;
        delete)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '(--force -f)''--force[Skip confirmation and suppress not-found errors]' \\
            '(--force -f)''-f[Skip confirmation and suppress not-found errors]' \\
            '--all[Delete all environment variables]'
          ;;
        import)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--from[Import from another environment]:value:_ggt_dynamic' \\
            '--from-file[Import from a .env file]:value:_files' \\
            '--include-values[Copy values when importing from another env]' \\
            '--all[Import all variables instead of specifying keys]'
          ;;
      esac
      ;;
  esac
}

_ggt_env() {
  local -a subcommands
  local state

  _arguments -C \\
    '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
    '--version[Print the ggt version]' \\
    '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
    '--telemetry[Enable telemetry]' \\
    '--json[Output as JSON where supported]' \\
    '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
    '1:subcommand:->subcommand' \\
    '*::arg:->args'

  case $state in
    subcommand)
      subcommands=(
        'list:List all environments'
        'ls:List all environments'
        'create:Create a new environment'
        'delete:Delete an environment'
        'unpause:Unpause a paused environment'
        'use:Switch the active environment for this directory'
      )
      _describe -t subcommands 'env subcommand' subcommands
      ;;
    args)
      case $words[1] in
        list|ls)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic'
          ;;
        create)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '--from[Clone from an existing environment]:value:_ggt_dynamic' \\
            '(--use -u)''--use[Switch to the new environment after creation]' \\
            '(--use -u)''-u[Switch to the new environment after creation]'
          ;;
        delete)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--force -f)''--force[Skip confirmation]' \\
            '(--force -f)''-f[Skip confirmation]'
          ;;
        unpause)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic'
          ;;
        use)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic'
          ;;
      esac
      ;;
  esac
}

_ggt_add() {
  local -a subcommands
  local state

  _arguments -C \\
    '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
    '--version[Print the ggt version]' \\
    '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
    '--telemetry[Enable telemetry]' \\
    '--json[Output as JSON where supported]' \\
    '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
    '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
    '--allow-different-app[Allow syncing with a different app]' \\
    '--allow-unknown-directory[Allow syncing to an existing directory]' \\
    '--allow[Enable allow flags (comma-separated)]:value: ' \\
    '--allow-all[Enable all --allow-* flags]' \\
    '1:subcommand:->subcommand' \\
    '*::arg:->args'

  case $state in
    subcommand)
      subcommands=(
        'model:Add a new data model'
        'action:Add an action to a model or as a global action'
        'route:Add an HTTP route'
        'field:Add a field to an existing model'
        'environment:Create a new environment by cloning'
        'env:Create a new environment by cloning'
      )
      _describe -t subcommands 'add subcommand' subcommands
      ;;
    args)
      case $words[1] in
        model)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
        action)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
        route)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
        field)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
        environment|env)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
      esac
      ;;
  esac
}


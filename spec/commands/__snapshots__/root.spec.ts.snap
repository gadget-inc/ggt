exports[`root > when var is given > prints the usage for set when --help is passed 1`] = `
"Set one or more environment variables

Accepts one or more KEY=value pairs. The value is everything after the
first =, so values can contain additional = characters. Use
--secret to mark the variables as write-only.

USAGE
  ggt var set <key=value> [flags]

ARGUMENTS
  key=value
        One or more key=value pairs. The value is everything after the first =,
        so values can contain = characters. Multiple pairs can be passed in a
        single invocation.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

  -s, --secret
        Mark the variable as secret (write-only). Secret variables are
        write-only — their values cannot be read back after being set. Use this
        for API keys, tokens, and other sensitive values.

EXAMPLES
  $ ggt var set API_KEY=abc123
  $ ggt var set SECRET=xyz --secret
  $ ggt var set KEY1=a KEY2=b
  $ ggt var set CONNECTION_STRING=postgres://user:pass@host/db
"
`;

exports[`root > when var is given > prints the usage for set when -h is passed 1`] = `
"Set one or more environment variables

USAGE
  ggt var set <key=value> [flags]

ARGUMENTS
  key=value    One or more key=value pairs

FLAGS
  -a, --app, --application <app>  Gadget app to use
  -e, --env, --environment <env>  Environment to use
  -s, --secret                    Mark the variable as secret (write-only)

EXAMPLES
  $ ggt var set API_KEY=abc123
  $ ggt var set SECRET=xyz --secret
  $ ggt var set KEY1=a KEY2=b
  $ ggt var set CONNECTION_STRING=postgres://user:pass@host/db

Run ggt var set --help for more information.
"
`;

exports[`root > when var is given > prints the usage when --help is passed 1`] = `
"Manage your app's environment variables

Environment variables are available as process.env.YOUR_VAR in your app code. Use them
for configuration like API keys and settings that differ between environments. Secret
variables are write-only — their values cannot be read back after being set.

USAGE
  ggt var <command> [flags]

COMMANDS
  list      List all environment variable keys
  get       Print the value of an environment variable
  set       Set one or more environment variables
  delete    Delete one or more environment variables
  import    Import variables from another environment or file

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

EXAMPLES
  $ ggt var list
  $ ggt var get DATABASE_URL
  $ ggt var set API_KEY=abc123
  $ ggt var set SECRET=xyz --secret
  $ ggt var set CONNECTION_STRING=postgres://user:pass@host/db
  $ ggt var delete API_KEY
  $ ggt var delete --all --force
  $ ggt var import --from staging --all
  $ ggt var import --from-file .env --all
"
`;

exports[`root > when var is given > prints the usage when -h is passed 1`] = `

exports[`root > when env is given > prints the usage when --help is passed 1`] = `
"Manage your app's environments

Environments are isolated copies of your app for development, staging, and testing. Each
environment has its own database, file tree, and environment variables. The production
environment cannot be deleted or used directly with ggt dev.

USAGE
  ggt env <command> [flags]

COMMANDS
  list       List all environments
  create     Create a new environment
  delete     Delete an environment
  unpause    Unpause a paused environment
  use        Switch the active environment for this directory

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

EXAMPLES
  $ ggt env list
  $ ggt env create staging
  $ ggt env create staging --from development
  $ ggt env delete staging --force
  $ ggt env unpause staging
  $ ggt env use staging
"
`;


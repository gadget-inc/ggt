// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`completion > shell generators > bash output matches snapshot 1`] = `
"# bash completion for ggt -*- shell-script -*-

_ggt_completions() {
  local cur="\${COMP_WORDS[COMP_CWORD]}"

  local prev="\${COMP_WORDS[COMP_CWORD-1]}"

  case "$prev" in
    --application|-a|--app|--environment|-e|--env|--log-level|-l|--prefer|--from|--to|--configure|-c)
      local IFS=$'\\n'
      COMPREPLY=($(ggt --__complete "\${COMP_WORDS[@]:1}" 2>/dev/null))
      return ;;
    --from-file)
      COMPREPLY=($(compgen -f -- "$cur"))
      return ;;
    --file-push-delay|--file-watch-debounce|--file-watch-poll-interval|--file-watch-poll-timeout|--file-watch-rename-timeout|--allow|--model|--app-name|--shopify-organization-id|--start|--port|-p)
      return ;;
  esac

  if [[ $COMP_CWORD -eq 1 ]]; then
    COMPREPLY=($(compgen -W "dev deploy status problems problem push pull var env envs add model action field shopify open list login logout logs log debugger whoami configure agent-plugin eval version completion --help -h --version --verbose -v --telemetry --json" -- "$cur"))
    return
  fi

  case "\${COMP_WORDS[1]}" in
    dev)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --log-level -l --my-logs -m --prefer --file-push-delay --file-watch-debounce --file-watch-poll-interval --file-watch-poll-timeout --file-watch-rename-timeout --no-logs --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    deploy)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --from --allow-different-app --allow-unknown-directory --force -f --allow-problems --allow-issues --allow-charges --allow-data-delete --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    status)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    problems|problem)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    push)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --to --allow-different-app --allow-unknown-directory --force -f --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    pull)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --from --allow-different-app --allow-unknown-directory --force -f --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    var)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "list get set delete import --application -a --app --environment -e --env --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          list)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          get)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          set)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --secret -s --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          delete)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --force -f --all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          import)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --from --from-file --include-values --all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    env|envs)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "list ls create delete unpause use --application -a --app --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          list|ls)
            COMPREPLY=($(compgen -W "--application -a --app --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          create)
            COMPREPLY=($(compgen -W "--application -a --app --from --use -u --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          delete)
            COMPREPLY=($(compgen -W "--application -a --app --force -f --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          unpause)
            COMPREPLY=($(compgen -W "--application -a --app --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          use)
            COMPREPLY=($(compgen -W "--application -a --app --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    add)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env|--allow) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "model action route field environment env --application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          model)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          action)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          route)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          field)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          environment|env)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    model)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env|--allow) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "add remove rename --application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          add)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          remove)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --force -f --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          rename)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    action)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env|--allow) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "add --application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          add)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --model --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    field)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env|--allow) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "add remove rename --application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          add)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          remove)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --force -f --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          rename)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    shopify)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        case "$w" in
          --application|-a|--app|--environment|-e|--env|--allow) __skip_next=1; continue ;;
        esac
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "connect --application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          connect)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --app-name --shopify-organization-id --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-different-app --allow-unknown-directory --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    open)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --show-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    list)
      COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    login)
      COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    logout)
      COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    logs|log)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --log-level -l --my-logs -m --follow -f --start --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    debugger)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --port -p --configure -c --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    whoami)
      COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    configure)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "show change clear --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          show)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          change)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          clear)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    agent-plugin)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "install update --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          install)
            COMPREPLY=($(compgen -W "--force -f --help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          update)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
    eval)
      COMPREPLY=($(compgen -W "--application -a --app --environment -e --env --allow-writes -w --allow --allow-all --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    version)
      COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
      ;;
    completion)
      local sub_cmd=
      local __skip_next=0
      for ((i=2; i < COMP_CWORD; i++)); do
        local w="\${COMP_WORDS[i]}"
        if [[ $__skip_next -eq 1 ]]; then
          __skip_next=0
          continue
        fi
        if [[ "$w" != -* ]]; then
          sub_cmd="$w"
          break
        fi
      done

      if [[ -z "$sub_cmd" ]]; then
        COMPREPLY=($(compgen -W "bash zsh fish --help -h --version --verbose -v --telemetry --json" -- "$cur"))
      else
        case "$sub_cmd" in
          bash)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          zsh)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          fish)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
          *)
            COMPREPLY=($(compgen -W "--help -h --version --verbose -v --telemetry --json" -- "$cur"))
            ;;
        esac
      fi
      ;;
  esac
}

complete -F _ggt_completions ggt
"
`;

exports[`completion > shell generators > fish output matches snapshot 1`] = `
"# fish completion for ggt

# Disable file completions by default
complete -c ggt -f

# Helper: invoke ggt's dynamic completer with correct partial
function __ggt_complete
  set -l tokens (commandline -opc)[2..]
  set -l current (commandline -ct)
  # fish reports the flag token as $current without a trailing space;
  # passing $current '' tells the handler to complete the flag value with an empty partial
  if string match -q -- '-*' $current
    ggt --__complete $tokens $current '' 2>/dev/null
  else
    ggt --__complete $tokens $current 2>/dev/null
  end
end

# Helper: check if a specific subcommand of a parent command has been entered
# Usage: __ggt_seen_subcommand parentName [parentAlias...] -- subName [subAlias...] -- valueFlagName ...
function __ggt_seen_subcommand
  set -l parents
  set -l subs
  set -l vflags
  set -l sep_count 0
  for arg in $argv
    if test $arg = '--'
      set sep_count (math $sep_count + 1)
    else if test $sep_count -eq 2
      set -a vflags $arg
    else if test $sep_count -eq 1
      set -a subs $arg
    else
      set -a parents $arg
    end
  end
  set -l cmd (commandline -opc)
  set -l found_parent 0
  set -l skip_next 0
  for word in $cmd
    if test $found_parent -eq 1
      if test $skip_next -eq 1
        set skip_next 0
        continue
      end
      if set -q vflags[1]; and contains -- $word $vflags
        set skip_next 1
        continue
      end
      if contains -- $word $subs
        return 0
      end
    end
    if contains -- $word $parents
      set found_parent 1
    end
  end
  return 1
end

# Helper: check if we are positioned for a subcommand (parent seen, no subcommand yet)
# Usage: __ggt_needs_subcommand parentName [parentAlias...] -- valueFlagName ...
function __ggt_needs_subcommand
  set -l parents
  set -l vflags
  set -l after_sep 0
  for a in $argv
    if test $a = '--'
      set after_sep 1
    else if test $after_sep -eq 1
      set -a vflags $a
    else
      set -a parents $a
    end
  end
  set -l cmd (commandline -opc)
  set -l found_parent 0
  set -l skip_next 0
  for word in $cmd
    if test $found_parent -eq 1
      if test $skip_next -eq 1
        set skip_next 0
        continue
      end
      if contains -- $word $vflags
        set skip_next 1
        continue
      end
      if string match -q -- '-*' $word
        continue
      end
      return 1
    end
    if contains -- $word $parents
      set found_parent 1
    end
  end
  # parent was found but no subcommand yet
  if test $found_parent -eq 1
    return 0
  end
  return 1
end

# Root flags
complete -c ggt -n '__fish_use_subcommand' -l help -s h -d 'Show command help'
complete -c ggt -n '__fish_use_subcommand' -l version -d 'Print the ggt version'
complete -c ggt -n '__fish_use_subcommand' -l verbose -s v -d 'Increase output verbosity (-vv for debug, -vvv for trace)'
complete -c ggt -n '__fish_use_subcommand' -l telemetry -d 'Enable telemetry'
complete -c ggt -n '__fish_use_subcommand' -l json -d 'Output as JSON where supported'

# Commands
complete -c ggt -n '__fish_use_subcommand' -a 'dev' -d 'Sync files and stream logs locally'
complete -c ggt -n '__fish_use_subcommand' -a 'deploy' -d 'Deploy an environment to production'
complete -c ggt -n '__fish_use_subcommand' -a 'status' -d 'Show sync state and pending file changes'
complete -c ggt -n '__fish_use_subcommand' -a 'problems' -d 'Show errors and warnings in your app'
complete -c ggt -n '__fish_use_subcommand' -a 'problem' -d 'Show errors and warnings in your app'
complete -c ggt -n '__fish_use_subcommand' -a 'push' -d 'Upload local file changes to Gadget'
complete -c ggt -n '__fish_use_subcommand' -a 'pull' -d 'Download environment files to your local directory'
complete -c ggt -n '__fish_use_subcommand' -a 'var' -d 'Manage your app'\\''s environment variables'
complete -c ggt -n '__fish_use_subcommand' -a 'env' -d 'Manage your app'\\''s environments'
complete -c ggt -n '__fish_use_subcommand' -a 'envs' -d 'Manage your app'\\''s environments'
complete -c ggt -n '__fish_use_subcommand' -a 'add' -d 'Add resources to your app'
complete -c ggt -n '__fish_use_subcommand' -a 'model' -d 'Add and manage models in your app'
complete -c ggt -n '__fish_use_subcommand' -a 'action' -d 'Add and manage actions'
complete -c ggt -n '__fish_use_subcommand' -a 'field' -d 'Manage fields on your models'
complete -c ggt -n '__fish_use_subcommand' -a 'shopify' -d 'Manage Shopify connection'
complete -c ggt -n '__fish_use_subcommand' -a 'open' -d 'Open your app in a browser'

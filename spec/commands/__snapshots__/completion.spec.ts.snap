  local -a subcommands
  local state

  _arguments -C \\
    '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
    '--version[Print the ggt version]' \\
    '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\

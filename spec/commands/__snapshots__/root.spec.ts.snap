exports[`root > when pull is given > prints the usage when --help is passed 1`] = `
"Download environment files to your local directory

Downloads all environment file changes since the last sync to your local directory. If
you also have local changes since the last sync, you'll be prompted to discard those
local changes or abort. Use --force to skip the prompt and discard automatically.

USAGE
  ggt pull [flags]

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment, --from <env>
        Environment to pull from. Defaults to the development environment
        recorded in .gadget/sync.json.

  -f, --force
        Pull without prompting, discarding local changes. Any local changes
        since the last sync are overwritten by the environment's files.

ADDITIONAL FLAGS
      --allow <flag,...>
        Enable allow flags (comma-separated)

      --allow-all
        Enable all --allow-* flags

      --allow-different-app
        Allow syncing with a different app. Overrides the app recorded in
        .gadget/sync.json with the one specified by --app. Use this when you
        want to reuse an existing directory for a different app.

      --allow-unknown-directory
        Allow syncing to an existing directory. Normally, a directory must be
        empty or already contain .gadget/sync.json. Use this when you want to
        initialize sync in a directory with existing content.

EXAMPLES
  $ ggt pull
  $ ggt pull --env staging
  $ ggt pull --env production --force

SEE ALSO
  ggt push — Upload local file changes to Gadget.
  ggt dev — Bidirectional file sync with real-time watching.
"
`;

exports[`root > when pull is given > prints the usage when -h is passed 1`] = `
"Download environment files to your local directory

USAGE
  ggt pull [flags]

FLAGS
  -a, --app, --application <app>          Gadget app to use
  -e, --env, --environment, --from <env>  Environment to pull from
  -f, --force                             Pull without prompting, discarding local changes

EXAMPLES
  $ ggt pull
  $ ggt pull --env staging
  $ ggt pull --env production --force

Run ggt pull --help for more information.
"
`;

exports[`root > when push is given > prints the usage when --help is passed 1`] = `
"Upload local file changes to Gadget

Uploads all local file changes since the last sync to your Gadget environment. If the
environment also has changes since the last sync, you'll be prompted to discard those
environment changes or abort. Use --force to skip the prompt and discard automatically.

USAGE
  ggt push [flags]

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment, --to <env>
        Environment to push to. Defaults to the development environment recorded
        in .gadget/sync.json. Production cannot be pushed to.

  -f, --force
        Push without prompting, discarding environment changes. Any changes on
        the environment since the last sync are overwritten by your local files.

ADDITIONAL FLAGS
      --allow <flag,...>
        Enable allow flags (comma-separated)

      --allow-all
        Enable all --allow-* flags

      --allow-different-app
        Allow syncing with a different app. Overrides the app recorded in
        .gadget/sync.json with the one specified by --app. Use this when you
        want to reuse an existing directory for a different app.

      --allow-unknown-directory
        Allow syncing to an existing directory. Normally, a directory must be
        empty or already contain .gadget/sync.json. Use this when you want to
        initialize sync in a directory with existing content.

EXAMPLES
  $ ggt push
  $ ggt push --env main
  $ ggt push --env main --force

SEE ALSO
  ggt pull — Download environment files.
  ggt dev — Bidirectional file sync with real-time watching.
"
`;

exports[`root > when push is given > prints the usage when -h is passed 1`] = `
"Upload local file changes to Gadget

USAGE
  ggt push [flags]

FLAGS
  -a, --app, --application <app>        Gadget app to use
  -e, --env, --environment, --to <env>  Environment to push to
  -f, --force                           Push without prompting, discarding environment changes

EXAMPLES
  $ ggt push
  $ ggt push --env main
  $ ggt push --env main --force

Run ggt push --help for more information.
"
`;


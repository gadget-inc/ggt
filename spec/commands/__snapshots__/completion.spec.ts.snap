_ggt() {
  local -a commands
  local state
  # Save the full word list before _arguments -C locally scopes $words
  local -a _ggt_words=("\${words[@]}")

  _arguments -C \\
    '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
    '--version[Print the ggt version]' \\
    '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
    '--telemetry[Enable telemetry]' \\
    '--json[Output as JSON where supported]' \\
    '1:command:->command' \\
    '*::arg:->args'

  case $state in
    command)
      commands=(
        'dev:Sync files and stream logs locally'
        'deploy:Deploy an environment to production'
        'status:Show sync state and pending file changes'
        'problems:Show errors and warnings in your app'
        'problem:Show errors and warnings in your app'
        'push:Upload local file changes to Gadget'
        'pull:Download environment files to your local directory'
        'var:Manage your app'\\''s environment variables'
        'env:Manage your app'\\''s environments'
        'envs:Manage your app'\\''s environments'
        'add:Add resources to your app'
        'model:Add and manage models in your app'
        'action:Add and manage actions'
        'field:Manage fields on your models'
        'shopify:Manage Shopify connection'
        'open:Open your app in a browser'
        'list:List your Gadget apps'
        'login:Log in to Gadget'
        'logout:Log out of Gadget'
        'logs:Print recent logs or stream logs from your app'
        'log:Print recent logs or stream logs from your app'
        'debugger:Connect a debugger to your app'\\''s environment'
        'whoami:Show the current logged-in user'
        'configure:Manage ggt configuration'
        'agent-plugin:Manage plugins for AI coding assistants'
        'eval:Evaluate a JavaScript snippet against your app'
        'version:Print the currently installed version'
        'completion:Generate shell completion scripts'
      )
      _describe -t commands 'ggt command' commands
      ;;
    args)
      case $words[1] in
        dev)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\
            '(--application -a --app)''--application[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''-a[Gadget app to use]:value:_ggt_dynamic' \\
            '(--application -a --app)''--app[Gadget app to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--environment[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''-e[Environment to use]:value:_ggt_dynamic' \\
            '(--environment -e --env)''--env[Environment to use]:value:_ggt_dynamic' \\
            '--allow-different-app[Allow syncing with a different app]' \\
            '--allow-unknown-directory[Allow syncing to an existing directory]' \\
            '(--log-level -l)''--log-level[Minimum log level to display]:value:_ggt_dynamic' \\
            '(--log-level -l)''-l[Minimum log level to display]:value:_ggt_dynamic' \\
            '(--my-logs -m)''--my-logs[Show only logs emitted by your code]' \\
            '(--my-logs -m)''-m[Show only logs emitted by your code]' \\
            '--prefer[Auto-resolve conflicts using the given source]:value:_ggt_dynamic' \\
            '--file-push-delay[Delay in ms before pushing file changes]:value: ' \\
            '--file-watch-debounce[Debounce in ms for file watch events]:value: ' \\
            '--file-watch-poll-interval[Interval in ms for polling file changes]:value: ' \\
            '--file-watch-poll-timeout[Timeout in ms for file watch polling]:value: ' \\
            '--file-watch-rename-timeout[Timeout in ms for detecting file renames]:value: ' \\
            '--no-logs[Don'\\''t stream logs while syncing]' \\
            '--allow[Enable allow flags (comma-separated)]:value: ' \\
            '--allow-all[Enable all --allow-* flags]'
          ;;
        deploy)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\
            '(--verbose -v)''--verbose[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '(--verbose -v)''-v[Increase output verbosity (-vv for debug, -vvv for trace)]' \\
            '--telemetry[Enable telemetry]' \\
            '--json[Output as JSON where supported]' \\

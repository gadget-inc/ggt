exports[`root > when var is given > prints the usage for delete when --help is passed 1`] = `
"Delete one or more environment variables

Prompts for confirmation before deleting unless --force is passed. Use
--all to delete every variable in the environment. With --force,
missing keys are silently ignored instead of causing an error.

USAGE
  ggt var delete [key] [flags]

ARGUMENTS
  key
        Variable name(s) to delete. One or more keys separated by spaces. Use
        --all to delete every variable.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

  -f, --force
        Skip confirmation and suppress not-found errors. Skips the confirmation
        prompt and silently ignores keys that don't exist.

      --all
        Delete all environment variables. Deletes every variable in the
        environment. Combine with --force to skip confirmation.

EXAMPLES
  $ ggt var delete API_KEY
  $ ggt var delete KEY1 KEY2
  $ ggt var delete --all --force
"
`;

exports[`root > when var is given > prints the usage for delete when -h is passed 1`] = `
"Delete one or more environment variables

USAGE
  ggt var delete [key] [flags]

ARGUMENTS
  key         Variable name(s) to delete

FLAGS
  -a, --app, --application <app>  Gadget app to use
  -e, --env, --environment <env>  Environment to use
  -f, --force                     Skip confirmation and suppress not-found errors
      --all                       Delete all environment variables

EXAMPLES
  $ ggt var delete API_KEY
  $ ggt var delete KEY1 KEY2
  $ ggt var delete --all --force

Run ggt var delete --help for more information.
"
`;

exports[`root > when var is given > prints the usage for get when --help is passed 1`] = `
"Print the value of an environment variable

Prints the value of a single variable. Secret variables are write-only
and cannot be read back — an error is returned if you try.

USAGE
  ggt var get <key> [flags]

ARGUMENTS
  key
        Variable name. Case-sensitive. Secret variables cannot be read back.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

EXAMPLES
  $ ggt var get DATABASE_URL
  $ ggt var get API_KEY --app myapp --env staging
"
`;

exports[`root > when var is given > prints the usage for get when -h is passed 1`] = `
"Print the value of an environment variable

USAGE
  ggt var get <key> [flags]

ARGUMENTS
  key         Variable name

FLAGS
  -a, --app, --application <app>  Gadget app to use
  -e, --env, --environment <env>  Environment to use

EXAMPLES
  $ ggt var get DATABASE_URL
  $ ggt var get API_KEY --app myapp --env staging

Run ggt var get --help for more information.
"
`;

exports[`root > when var is given > prints the usage for import when --help is passed 1`] = `
"Import variables from another environment or file

Requires either --from (another environment) or --from-file (a
.env file) as the source. By default, variables are imported as
placeholders with empty values — pass --include-values to copy the
actual values. Secret values cannot be copied between environments.

USAGE
  ggt var import [key] [flags]

ARGUMENTS
  key
        Variable name(s) to import (or use --all). One or more keys to import.
        Use --all to import every variable from the source.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

      --all
        Import all variables instead of specifying keys. Imports every variable
        from the source instead of requiring individual key names.

      --from <env>
        Import from another environment. The name of the source environment to
        import from. Cannot be combined with --from-file.

      --from-file <path>
        Import from a .env file. Path to a .env file. Supports KEY=value format,
        comments (#), and quoted values. Cannot be combined with --from.

      --include-values
        Copy values when importing from another env. Without this flag, only the
        keys are imported as empty placeholders. Secret variable values cannot
        be copied between environments and are skipped.

EXAMPLES
  $ ggt var import --from staging --all
  $ ggt var import --from staging API_KEY DATABASE_URL
  $ ggt var import --from staging --include-values API_KEY
  $ ggt var import --from-file .env --all
"
`;

exports[`root > when var is given > prints the usage for import when -h is passed 1`] = `
"Import variables from another environment or file

USAGE
  ggt var import [key] [flags]

ARGUMENTS
  key         Variable name(s) to import (or use --all)

FLAGS
  -a, --app, --application <app>  Gadget app to use
  -e, --env, --environment <env>  Environment to use
      --all                       Import all variables instead of specifying keys
      --from <env>                Import from another environment
      --from-file <path>          Import from a .env file
      --include-values            Copy values when importing from another env

EXAMPLES
  $ ggt var import --from staging --all
  $ ggt var import --from staging API_KEY DATABASE_URL
  $ ggt var import --from staging --include-values API_KEY
  $ ggt var import --from-file .env --all

Run ggt var import --help for more information.
"
`;


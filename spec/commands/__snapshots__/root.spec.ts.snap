USAGE
  ggt agent-plugin install [flags]

FLAGS
  -f, --force             Overwrite existing files even if already present

EXAMPLES
  $ ggt agent-plugin install
  $ ggt agent-plugin install --force

Run ggt agent-plugin install --help for more information.
"
`;

exports[`root > when agent-plugin is given > prints the usage for update when --help is passed 1`] = `
"Update agent plugins to the latest version

Overwrites all agent plugin files with their latest versions. Prompts
before replacing AGENTS.md if it already exists. Skill files are
always replaced without prompting.

USAGE
  ggt agent-plugin update

EXAMPLES
  $ ggt agent-plugin update
"
`;


exports[`root > when env is given > prints the usage for unpause when --help is passed 1`] = `
"Unpause a paused environment

Environments are paused automatically after a period of inactivity.
This command resumes a paused environment so it can serve requests and
run actions again. Prints a message if the environment is already
active.

USAGE
  ggt env unpause <name> [flags]

ARGUMENTS
  name
        Environment name. Must match an existing environment in the app.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

EXAMPLES
  $ ggt env unpause staging
  $ ggt env unpause development --app myapp
"
`;

exports[`root > when env is given > prints the usage for unpause when -h is passed 1`] = `

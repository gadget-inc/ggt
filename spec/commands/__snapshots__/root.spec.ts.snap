exports[`root > when agent-plugin is given > prints the usage for install when --help is passed 1`] = `
"Install agent plugins into the current project

Writes AGENTS.md and Gadget skill files into your project. Existing
files are skipped unless --force is passed to overwrite them. The
project root is detected from .gadget/sync.json or defaults to the
current directory.

USAGE
  ggt agent-plugin install [flags]

FLAGS
  -f, --force
        Overwrite existing files even if already present. Overwrites existing
        AGENTS.md and skill files. Without this flag, existing files are left
        untouched.

EXAMPLES
  $ ggt agent-plugin install
  $ ggt agent-plugin install --force
"
`;

exports[`root > when agent-plugin is given > prints the usage for install when -h is passed 1`] = `

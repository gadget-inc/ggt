    '--telemetry[Enable telemetry]' \\
    '--json[Output as JSON where supported]' \\
    '1:subcommand:->subcommand' \\
    '*::arg:->args'

  case $state in
    subcommand)
      subcommands=(
        'show:Show current configured defaults'
        'change:Interactively change configuration options'
        'clear:Remove all configured defaults'
      )
      _describe -t subcommands 'configure subcommand' subcommands
      ;;
    args)
      case $words[1] in
        show)
          _arguments \\
            '(--help -h)''--help[Show command help]' \\
            '(--help -h)''-h[Show command help]' \\
            '--version[Print the ggt version]' \\

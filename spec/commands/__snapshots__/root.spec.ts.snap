exports[`root > when open is given > prints the usage when --help is passed 1`] = `
"Open your app in a browser

Opens the Gadget web editor for your app by default. The data and schema locations require a model
name or --show-all to pick from a list.

USAGE
  ggt open [location] [model] [flags]

ARGUMENTS
  location
        Page to open: logs, permissions, data, or schema. One of: logs,
        permissions, data, schema. Opens the app editor when omitted.

  model
        Model name for data or schema locations. Required for data and schema
        locations. Use --show-all to pick from a list instead.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

      --show-all
        Prompt to pick a model from the full list. Displays an interactive
        picker with all models in your app. Useful when you don't remember the
        exact model name.

EXAMPLES
  $ ggt open
  $ ggt open logs
  $ ggt open permissions
  $ ggt open data post
  $ ggt open schema post
  $ ggt open data --show-all
  $ ggt open schema --show-all
  $ ggt open data post --app myBlog --env staging

LOCATIONS
  location specifies the part of Gadget to open. By default it opens the app's editor.

    logs          Opens the log viewer for your environment.
    permissions   Opens the permissions settings page.
    data          Opens the data editor for a specific model.
    schema        Opens the schema editor for a specific model.
"
`;

exports[`root > when open is given > prints the usage when -h is passed 1`] = `
"Open your app in a browser

USAGE
  ggt open [location] [model] [flags]

ARGUMENTS
  location    Page to open: logs, permissions, data, or schema
  model       Model name for data or schema locations

FLAGS
  -a, --app, --application <app>  Gadget app to use
  -e, --env, --environment <env>  Environment to use
      --show-all                  Prompt to pick a model from the full list

EXAMPLES
  $ ggt open
  $ ggt open logs
  $ ggt open permissions
  $ ggt open data post
  $ ggt open schema post
  $ ggt open data --show-all
  $ ggt open schema --show-all
  $ ggt open data post --app myBlog --env staging

Run ggt open --help for more information.
"
`;

exports[`root > when problems is given > prints the usage when --help is passed 1`] = `
"Show errors and warnings in your app

Fetches issues that would block a deploy from the Gadget platform for your app's environment.
Issues include type errors, missing action files, and schema conflicts. Exits
cleanly with a success message when no problems are found.

USAGE
  ggt problems [flags]

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

EXAMPLES
  $ ggt problems
  $ ggt problems --app myBlog
  $ ggt problems --env staging
  $ ggt problems --app myBlog --env production
"
`;

exports[`root > when problems is given > prints the usage when -h is passed 1`] = `

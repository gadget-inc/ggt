exports[`root > when debugger is given > prints the usage when --help is passed 1`] = `
"Connect a debugger to your app's environment

Starts a local Chrome DevTools Protocol (CDP) proxy that forwards debugging traffic
between your editor and your Gadget environment. Supported clients include VS Code,
Cursor, and Chrome DevTools. Use --configure vscode to generate
.vscode/launch.json and tasks.json for one-click attach debugging. Press Ctrl+C to
stop the proxy.

USAGE
  ggt debugger [directory] [flags]

ARGUMENTS
  directory
        App directory to use. Defaults to the current working directory when
        omitted.

FLAGS
  -a, --app, --application <app>
        Gadget app to use. The app slug is the subdomain portion of your app URL
        (e.g., my-app from my-app.gadget.app). Can be omitted when
        .gadget/sync.json already records the app.

  -c, --configure <editor>
        Write editor debug config files (vscode, cursor). Generates
        .vscode/launch.json and tasks.json for one-click attach debugging. Works
        with both VS Code and Cursor.

  -e, --env, --environment <env>
        Environment to use. Defaults to the development environment. Production
        is read-only for most commands.

  -p, --port <port>
        Local port for the CDP proxy. Defaults to 9229. Change this if the
        default port is already in use.

EXAMPLES
  $ ggt debugger
  $ ggt debugger --port 9230
  $ ggt debugger --configure vscode
  $ ggt debugger --configure cursor
  $ ggt debugger --app myApp --env development
  $ ggt debugger --port 9230 --configure vscode
"
`;

exports[`root > when debugger is given > prints the usage when -h is passed 1`] = `
